{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@webgl-scroll/core": ["packages/core/src/index.ts"],
      "@webgl-scroll/effects": ["packages/effects/src/index.ts"],
      "@webgl-scroll/react": ["packages/react/src/index.ts"]
    },
    "types": ["node"]
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "examples/*/src/**/*.ts",
    "examples/*/src/**/*.tsx"
  ]
}
