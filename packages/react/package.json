{
  "name": "@webgl-scroll/react",
  "version": "0.3.0",
  "description": "React bindings for @webgl-scroll/core.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/agenticnoob/webgl-scroll",
    "directory": "packages/react"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean --external @webgl-scroll/core --external react --external react-dom",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@webgl-scroll/core": "^0.3.0",
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  }
}
