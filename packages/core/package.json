{
  "name": "@webgl-scroll/core",
  "version": "0.3.0",
  "description": "Core runtime for composable WebGL scroll effects.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/agenticnoob/webgl-scroll",
    "directory": "packages/core"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "gsap": "^3.15.0",
    "three": "^0.184.0"
  }
}
